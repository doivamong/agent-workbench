{#- The DYNAMIC region of the dashboard (everything derived from gather()). Rendered
    standalone by GET /fragment (HTMX day-change / refresh, swapped into #dyn) and included
    by dashboard.html.jinja for the initial page. UI text via the i18n catalog (`t`); the
    honesty model is unchanged: a skill is "not measured", never "dead", unless telemetry is
    wired AND has data. NOTE: the tier_dist loop uses `td` (not `t`) so it never shadows the
    i18n catalog. -#}

{#- ===== Honesty banner: 3 states (not-wired / wired-but-empty / measured) ===== -#}
{% if not ctx.wired %}
<div class="banner" role="status">
  <span class="banner__dot" aria-hidden="true"></span>
  <span class="banner__txt">{{ t.banner_notwired|safe }}</span>
</div>
{% elif not measured %}
<div class="banner" role="status">
  <span class="banner__dot" aria-hidden="true"></span>
  <span class="banner__txt">{{ t.banner_empty|safe }}</span>
</div>
{%- elif measured and n_zero %}
{#- MEASURED state: the only state that prints the 0-fire labels, so it must carry the
    caveat that the metric only counts skills NAMED in a prompt. Neutral surface (override
    the amber .banner), NOT a warning — an un-named skill is information, not an error. -#}
<div class="banner" role="status"
     style="background:var(--surface-2);border-color:var(--border)">
  <span class="banner__dot" aria-hidden="true" style="background:var(--text-dim)"></span>
  <span class="banner__txt">{{ t.banner_measured|safe }}</span>
</div>
{% endif %}

{#- ===== KPI strip ===== -#}
<section class="kpibar" aria-label="{{ t.kpibar_aria }}">
  <div class="kpi">
    <span class="kpi__label">{{ t.kpi_skills }}</span>
    <span class="kpi__value"><span class="kit-num kit-num--xl">{{ n_skills }}</span></span>
    <span class="kpi__sub">
      {%- if measured %}{{ t.kpi_skills_sub_measured.format(dead=dead) }}{% else %}{{ t.kpi_skills_sub_unmeasured }}{% endif -%}
    </span>
  </div>
  <div class="kpi">
    <span class="kpi__label">{{ t.kpi_namecalls.format(days=days) }}</span>
    <span class="kpi__value">
      {%- if measured %}<span class="kit-num kit-num--xl kit-num--accent">{{ ctx.total }}</span><span class="kit-num__unit">{{ t.unit_calls }}</span>
      {%- else %}<span class="kit-num kit-num--lg muted">{{ t.kpi_namecalls_unmeasured }}</span>{% endif -%}
    </span>
    <span class="kpi__sub">{% if measured %}{{ t.kpi_namecalls_sub_measured.format(avg=(ctx.total / days)|round(1)) }}{% else %}{{ t.kpi_namecalls_sub_unmeasured }}{% endif %}</span>
  </div>
  <div class="kpi">
    <span class="kpi__label">{{ t.kpi_tools }}</span>
    <span class="kpi__value"><span class="kit-num kit-num--xl {{ 'kit-num--warn' if ctx.tools_missing else 'kit-num--ok' }}">{{ ctx.tools_present|length }}</span><span class="kit-num__unit">/ {{ n_tools_full }}</span></span>
    <span class="kpi__sub">{% if ctx.tools_missing %}{{ t.kpi_tools_sub_missing.format(n=ctx.tools_missing|length) }}{% else %}{{ t.kpi_tools_sub_ok }}{% endif %}</span>
  </div>
  <div class="kpi">
    <span class="kpi__label">{{ t.kpi_hooks }}</span>
    <span class="kpi__value"><span class="kit-num kit-num--xl kit-num--ok">{{ ctx.n_hooks }}</span></span>
    <span class="kpi__sub">{{ t.kpi_hooks_sub.format(n=ctx.events|length) }}</span>
  </div>
  <div class="kpi">
    <span class="kpi__label">{{ t.kpi_mem }}</span>
    <span class="kpi__value">
      {%- if mem_pct is not none %}<span class="kit-num kit-num--xl {{ 'kit-num--warn' if mem_pct >= 75 else '' }}">{{ mem_pct }}</span><span class="kit-num__unit">%</span>
      {%- else %}<span class="kit-num kit-num--lg muted">—</span>{% endif -%}
    </span>
    <span class="kpi__sub">{% if ctx.mem.present %}{{ t.kpi_mem_sub_present.format(facts=ctx.mem.facts) }}{% else %}{{ t.kpi_mem_sub_absent }}{% endif %}</span>
  </div>
</section>

<div class="grid">

  {#- ===== Telemetry timeseries (chart or honest empty) ===== -#}
  <section class="panel span-4" aria-labelledby="h-tele">
    <div class="panel__head">
      <div>
        <div class="panel__eyebrow">{{ t.panel_telemetry_eyebrow }}</div>
        <h2 id="h-tele">{{ t.panel_telemetry_h2 }}</h2>
      </div>
      {% if measured %}<span class="badge"><span class="kit-num">{{ ctx.total }}</span>&nbsp;{{ t.badge_total }}</span>
      {% else %}<span class="badge badge--warn">{{ t.badge_unmeasured }}</span>{% endif %}
    </div>
    {% if measured %}
    <div class="chart-box">
      <canvas id="chart-timeseries" role="img"
        aria-label="{{ t.chart_ts_aria.format(days=days) }}"></canvas>
    </div>
    <p class="section-foot">{{ t.ts_foot|safe }}</p>
    {% else %}
    <div class="empty">
      <span class="empty__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="26" height="26"><path d="M4 19V5m0 14h16M8 15l3-4 3 2 4-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <span class="empty__title">{{ t.empty_ts_title }}</span>
      <span class="empty__msg">
        {% if ctx.wired %}{{ t.empty_ts_wired }}
        {% else %}{{ t.empty_ts_notwired|safe }}{% endif %}
      </span>
    </div>
    {% endif %}
  </section>

  {#- ===== Tier distribution (static property → always honest) ===== -#}
  <section class="panel span-2" aria-labelledby="h-tiers">
    <div class="panel__head">
      <div>
        <div class="panel__eyebrow">{{ t.panel_tiers_eyebrow }}</div>
        <h2 id="h-tiers">{{ t.panel_tiers_h2 }}</h2>
      </div>
    </div>
    <div class="chart-box" style="height:200px">
      <canvas id="chart-tiers" role="img" aria-label="{{ t.chart_tiers_aria }}"></canvas>
    </div>
    <div class="chips" style="margin-top:var(--sp-4)">
      {% for td in tier_dist %}
      <span class="chip"><span class="dot dot--{{ td.tier }}"></span>{{ td.label }} <span class="kit-num">{{ td.count }}</span></span>
      {% endfor %}
    </div>
  </section>

  {#- ===== Skills table (tier filter swaps only #skills-region) ===== -#}
  <section class="panel span-6" aria-labelledby="h-skills">
    <div class="panel__head">
      <div>
        <div class="panel__eyebrow">{{ t.panel_skills_eyebrow }}</div>
        <h2 id="h-skills">{{ t.panel_skills_h2|safe }}</h2>
      </div>
      <div class="row wrap" style="gap:var(--sp-3)">
        <label class="control">
          <span class="control__label">{{ t.filter_tier }}</span>
          <select name="tier" class="control__input"
                  hx-get="/fragment/skills" hx-target="#skills-region" hx-swap="innerHTML"
                  hx-include="[name='days']" hx-trigger="change">
            {% for opt in tiers_for_filter %}
            <option value="{{ opt.value }}" {{ 'selected' if opt.value == active_tier else '' }}>{{ opt.label }}</option>
            {% endfor %}
          </select>
        </label>
        <span class="badge"><span class="kit-num">{{ n_skills }}</span>&nbsp;{{ t.badge_n_skills }}</span>
        {% if measured %}<span class="badge badge--dead"><span class="kit-num">{{ dead }}</span>&nbsp;{{ t.badge_dead }}</span>{% endif %}
      </div>
    </div>
    {#- Persistent scroll wrapper: the tier filter swaps only the <table> inside this
        div, so the .table-scroll box (and its mobile horizontal scroll) survives the
        swap and the fragment stays a pure <table> partial. -#}
    <div id="skills-region" class="table-scroll" tabindex="0" role="region"
         aria-label="{{ t.skills_region_aria }}">{% include "_skills.html.jinja" %}</div>
  </section>

  {#- ===== Tools ===== -#}
  <section class="panel span-3" aria-labelledby="h-tools">
    <div class="panel__head">
      <div>
        <div class="panel__eyebrow">{{ t.panel_tools_eyebrow }}</div>
        <h2 id="h-tools">{{ t.panel_tools_h2 }}</h2>
      </div>
      <span class="badge {{ 'badge--warn' if ctx.tools_missing else 'badge--ok' }}">
        <span class="kit-num">{{ ctx.tools_present|length }}/{{ n_tools_full }}</span></span>
    </div>
    <div class="row row--baseline" style="margin-bottom:var(--sp-3)">
      <span class="kit-num kit-num--xl {{ 'kit-num--warn' if ctx.tools_missing else 'kit-num--ok' }}">{{ ctx.tools_present|length }}</span>
      <span class="kit-num__unit">/ {{ n_tools_full }} {{ t.tools_present_unit }}</span>
    </div>
    <div class="meter {{ 'meter--warn' if ctx.tools_missing else 'meter--ok' }}" aria-hidden="true">
      <span class="meter__fill" style="width:{{ (100 * ctx.tools_present|length / n_tools_full)|round|int if n_tools_full else 100 }}%"></span>
    </div>
    {% if ctx.tools_missing %}
    <p class="section-foot">{{ t.tools_foot_missing.format(n=ctx.tools_missing|length) }}</p>
    <div class="chips">
      {% for m in ctx.tools_missing %}<span class="chip chip--miss">{{ m }}</span>{% endfor %}
    </div>
    {% else %}
    <p class="section-foot">{{ t.tools_foot_ok|safe }}</p>
    {% endif %}
  </section>

  {#- ===== Memory ===== -#}
  <section class="panel span-3" aria-labelledby="h-mem">
    <div class="panel__head">
      <div>
        <div class="panel__eyebrow">{{ t.panel_mem_eyebrow }}</div>
        <h2 id="h-mem">{{ t.panel_mem_h2 }}</h2>
      </div>
      {% if mem_pct is not none %}
      <span class="badge {{ 'badge--warn' if mem_pct >= 75 else 'badge--ok' }}"><span class="kit-num">{{ mem_pct }}%</span>&nbsp;{{ t.badge_mem_used }}</span>
      {% else %}<span class="badge badge--warn">—</span>{% endif %}
    </div>
    {% if ctx.mem.present %}
    <div class="row row--between row--baseline" style="margin-bottom:var(--sp-2)">
      <span><span class="kit-num kit-num--xl {{ 'kit-num--warn' if mem_pct >= 75 else '' }}">{{ (ctx.mem.used / 1024)|round(1) }}</span><span class="kit-num__unit">/ {{ (ctx.mem.budget / 1024)|round|int }} KB</span></span>
      <span class="kit-num kit-num--lg">{{ mem_pct }}<span class="kit-num__unit">%</span></span>
    </div>
    <div class="meter {{ 'meter--warn' if mem_pct >= 75 else 'meter--ok' }}" aria-label="{{ t.mem_meter_aria.format(pct=mem_pct) }}">
      <span class="meter__fill" style="width:{{ mem_pct }}%"></span>
    </div>
    <p class="section-foot">{{ t.mem_foot_main.format(facts=ctx.mem.facts, dangling=ctx.mem.dangling) }}{% if mem_pct >= 75 %}{{ t.mem_foot_over }}{% endif %}.</p>
    {# Day-1-empty signal: live recall empty (fresh clone) or fell back to the repo template — say so plainly so the panel can't read as a green "memory works" (mirrors recall_doctor) #}
    {% if not ctx.mem.live or ctx.mem.facts == 0 %}<p class="section-foot">{{ t.mem_day1_empty }}</p>{% endif %}
    {# Fuller hygiene line — only when memory_audit actually ran (key present); absent => budget-only, no fabricated 0 (measurement-honesty) #}
    {% if ctx.mem.warns is defined %}<p class="section-foot">{{ t.mem_audit_summary.format(errors=ctx.mem.errors, warns=ctx.mem.warns) }}</p>{% endif %}
    {% else %}
    <div class="empty" style="padding:var(--sp-5)">
      <span class="empty__title">{{ t.empty_mem_title }}</span>
      <span class="empty__msg">{{ t.empty_mem_msg }}</span>
    </div>
    {% endif %}
  </section>

  {#- ===== Hooks ===== -#}
  <section class="panel span-6" aria-labelledby="h-hooks">
    <div class="panel__head">
      <div>
        <div class="panel__eyebrow">{{ t.panel_hooks_eyebrow }}</div>
        <h2 id="h-hooks">{{ t.panel_hooks_h2 }}</h2>
      </div>
      <span class="badge badge--ok"><span class="kit-num">{{ ctx.n_hooks }}</span>&nbsp;{{ t.badge_hooks }}</span>
    </div>
    <div class="chips">
      {% for e in ctx.events %}<span class="chip"><span class="chip__dot"></span>{{ e }}</span>
      {% else %}<span class="muted">{{ t.hooks_empty }}</span>{% endfor %}
    </div>
  </section>

</div>

{#- Chart data embedded (NOT fetched) so the page is fully offline. Inside #dyn so a
    day-change / refresh swap carries fresh data; dashboard.js re-inits on htmx:afterSwap. -#}
<script id="chart-data" type="application/json">{{ chart_json|safe }}</script>
