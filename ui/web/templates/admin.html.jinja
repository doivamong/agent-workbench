{#- Agent Workbench — /admin action surface (opt-in; always mounted, inert until a password is set — login is the gate).
    Same design language / tokens as the read-only dashboard. Fully offline (vendored htmx +
    css, no external refs). Every action is a POST form carrying the per-process CSRF token;
    results are HTMX-swapped into #admin-result. UI copy via the i18n catalog (`t`) — VI by
    default, EN via the switcher; server-rendered result messages are localized in admin.py. -#}
<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ t.admin_meta_title }}</title>
  <link rel="stylesheet" href="{{ url_for('static', filename='dashboard.css') }}">
  <script src="{{ url_for('static', filename='htmx.min.js') }}" defer></script>
  <script src="{{ url_for('static', filename='admin.js') }}" defer></script>
</head>
<body>
<a class="skip" href="#admin-actions">{{ t.admin_skip_to_actions }}</a>

<div class="shell">

  <header class="topbar">
    <div class="topbar__row">
      <div class="topbar__mark">
        <svg class="topbar__logo" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2.5 20.5 7v10L12 21.5 3.5 17V7L12 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M12 8v5m0 3h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <div>
          <div class="panel__eyebrow">{{ t.admin_eyebrow }}</div>
          <h1>{{ t.admin_h1 }}</h1>
        </div>
      </div>
      <div class="topbar__meta">
        <span class="env-pill"><span class="env-pill__live" aria-hidden="true"></span> {{ t.pill_local }}</span>
        <span class="env-pill kit-num">{{ host }}:{{ port }}</span>
        {#- Reachability badge — driven by the REAL bind host (not a guess). 'lan' = reachable on
            the local network (read-only); 'localhost' = this machine only. A public bind never
            reaches here (it is refused at startup — see ui/bind_policy.py). -#}
        <span class="env-pill"{% if bind_scope == 'lan' %} style="background:var(--danger-dim);border-color:var(--accent-deep)"{% endif %}>
          {%- if bind_scope == 'localhost' %}{{ t.admin_reach_localhost }}
          {%- elif bind_scope == 'lan' %}{{ t.admin_reach_lan }}
          {%- else %}{{ t.admin_reach_other }}{% endif -%}
        </span>
        {% include "_lang_switch.html.jinja" %}
        <a class="btn" href="/">{{ t.admin_back_dashboard }}</a>
        {% if auth_enabled %}
        <form method="post" action="/admin/logout" style="display:inline">
          <input type="hidden" name="csrf" value="{{ token }}">
          <button class="btn" type="submit">{{ t.admin_logout }}</button>
        </form>
        {% endif %}
      </div>
    </div>

    {#- Honest-limit banner — load-bearing, not decoration. The page is only reachable after
        login (password mode), so the relevant limit is cleartext-over-HTTP, not local trust. -#}
    <div class="banner" role="alert" style="background:var(--danger-dim);border-color:var(--accent-deep)">
      <span class="banner__dot" aria-hidden="true" style="background:var(--accent)"></span>
      <span class="banner__txt">{{ t.admin_banner|safe }}</span>
    </div>
  </header>

  <main id="admin-actions">

    {#- Live result region (HTMX target) ===================================== -#}
    <div id="admin-result" class="admin-result-region" aria-live="polite"></div>

    <div class="grid">

      {#- Restart -#}
      <section class="panel span-2" aria-labelledby="a-restart">
        <div class="panel__head"><div>
          <div class="panel__eyebrow">{{ t.admin_restart_eyebrow }}</div>
          <h2 id="a-restart">{{ t.admin_restart_h2 }}</h2>
        </div></div>
        <p class="section-foot">{{ t.admin_restart_foot }}</p>
        <form hx-post="/admin/action/restart" hx-target="#admin-result" hx-swap="innerHTML"
              hx-confirm="{{ t.admin_restart_confirm }}" class="admin-form">
          <input type="hidden" name="csrf" value="{{ token }}">
          <button type="submit" class="btn">{{ t.admin_restart_btn }}</button>
        </form>
      </section>

      {#- Snapshot -#}
      <section class="panel span-2" aria-labelledby="a-snap">
        <div class="panel__head"><div>
          <div class="panel__eyebrow">{{ t.admin_snap_eyebrow }}</div>
          <h2 id="a-snap">{{ t.admin_snap_h2 }}</h2>
        </div></div>
        <p class="section-foot">{{ t.admin_snap_foot|safe }}</p>
        <form hx-post="/admin/action/snapshot" hx-target="#admin-result" hx-swap="innerHTML" class="admin-form">
          <input type="hidden" name="csrf" value="{{ token }}">
          <button type="submit" class="btn">{{ t.admin_snap_btn }}</button>
        </form>
      </section>

      {#- Pack -#}
      <section class="panel span-2" aria-labelledby="a-pack">
        <div class="panel__head"><div>
          <div class="panel__eyebrow">{{ t.admin_pack_eyebrow }}</div>
          <h2 id="a-pack">{{ t.admin_pack_h2 }}</h2>
        </div></div>
        <p class="section-foot">{{ t.admin_pack_foot|safe }}</p>
        <form hx-post="/admin/action/pack" hx-target="#admin-result" hx-swap="innerHTML" class="admin-form">
          <input type="hidden" name="csrf" value="{{ token }}">
          <button type="submit" class="btn">{{ t.admin_pack_btn }}</button>
        </form>
      </section>

      {#- Verify -#}
      <section class="panel span-3" aria-labelledby="a-verify">
        <div class="panel__head"><div>
          <div class="panel__eyebrow">{{ t.admin_verify_eyebrow }}</div>
          <h2 id="a-verify">{{ t.admin_verify_h2 }}</h2>
        </div></div>
        {% if releases %}
        <form hx-post="/admin/action/verify" hx-target="#admin-result" hx-swap="innerHTML" class="admin-form">
          <input type="hidden" name="csrf" value="{{ token }}">
          <label class="control">
            <span class="control__label">{{ t.admin_verify_label }}</span>
            <select name="release" class="control__input" required>
              {% for r in releases %}<option value="{{ r.name }}">{{ r.name }} · {{ r.mtime }}</option>{% endfor %}
            </select>
          </label>
          <button type="submit" class="btn">{{ t.admin_verify_btn }}</button>
        </form>
        {% else %}
        <p class="section-foot muted">{{ t.admin_verify_empty|safe }}</p>
        {% endif %}
      </section>

      {#- Restore (guarded) -#}
      <section class="panel span-3" aria-labelledby="a-restore">
        <div class="panel__head"><div>
          <div class="panel__eyebrow">{{ t.admin_restore_eyebrow }}</div>
          <h2 id="a-restore">{{ t.admin_restore_h2 }}</h2>
        </div>
        {% if dirty %}<span class="badge badge--warn">{{ t.admin_restore_dirty_badge }}</span>{% endif %}</div>
        {% if snapshots %}
        <p class="section-foot">{{ t.admin_restore_foot }}</p>
        <form hx-post="/admin/restore/preview" hx-target="#admin-result" hx-swap="innerHTML" class="admin-form">
          <input type="hidden" name="csrf" value="{{ token }}">
          <label class="control">
            <span class="control__label">{{ t.admin_restore_label }}</span>
            <select name="snapshot" class="control__input" required>
              {% for s in snapshots %}<option value="{{ s.name }}">{{ s.name }} · {{ s.mtime }}</option>{% endfor %}
            </select>
          </label>
          <button type="submit" class="btn">{{ t.admin_restore_btn }}</button>
        </form>
        {% else %}
        <p class="section-foot muted">{{ t.admin_restore_empty|safe }}</p>
        {% endif %}
      </section>

      {#- System / LAN (read-only panel; actions added per slice) -#}
      <section class="panel span-3" aria-labelledby="a-system">
        <div class="panel__head"><div>
          <div class="panel__eyebrow">{{ t.admin_sys_eyebrow }}</div>
          <h2 id="a-system">{{ t.admin_sys_h2|safe }}</h2>
        </div></div>
        {% set lan = system.lan %}{% set au = system.autostart %}
        <p class="section-foot">
          {{ t.admin_sys_bind }} <span class="mono">{{ lan.effective_bind or "?" }}</span> ·
          {{ t.admin_sys_lan_default }} <strong>{{ t.admin_sys_on if lan.lan_default else t.admin_sys_off }}</strong> ·
          {{ t.admin_sys_autostart }} <strong>{% if au.registered %}{{ t.admin_sys_as_on }}{% elif au.error %}{{ t.admin_sys_as_err }}{% else %}{{ t.admin_sys_as_off }}{% endif %}</strong>
        </p>
        {% if lan.lan_urls %}
        <p class="section-foot">{{ t.admin_sys_phone }}
          {% for u in lan.lan_urls %}<span class="mono">{{ u }}</span>{% if not loop.last %}, {% endif %}{% endfor %}
        </p>
        {% endif %}
        {% if lan.firewall_command %}
        <p class="section-foot muted">{{ t.admin_sys_firewall_hint|safe }}</p>
        <p class="mono" style="word-break:break-all;font-size:.85em">{{ lan.firewall_command }}</p>
        {% endif %}

        <p class="section-foot">{{ t.admin_sys_actions_hint|safe }}</p>
        <div class="admin-form" style="display:flex;flex-wrap:wrap;gap:.5rem">
          {% set acts = [
            ("/admin/action/lan-enable",  t.admin_lan_enable_label, t.admin_lan_enable_confirm),
            ("/admin/action/lan-disable", t.admin_lan_disable_label, t.admin_lan_disable_confirm),
            ("/admin/action/firewall-open", t.admin_fw_open_label, t.admin_fw_open_confirm),
            ("/admin/action/autostart-enable", t.admin_as_enable_label, t.admin_as_enable_confirm),
            ("/admin/action/autostart-disable", t.admin_as_disable_label, t.admin_as_disable_confirm),
          ] %}
          {% for url, label, confirm in acts %}
          <form hx-post="{{ url }}" hx-target="#admin-result" hx-swap="innerHTML"
                hx-confirm="{{ confirm }}" style="display:inline">
            <input type="hidden" name="csrf" value="{{ token }}">
            <button type="submit" class="btn">{{ label }}</button>
          </form>
          {% endfor %}
        </div>
      </section>

      {#- Change admin password (only when auth is enabled) -#}
      {% if auth_enabled %}
      <section class="panel span-3" aria-labelledby="a-passwd">
        <div class="panel__head"><div>
          <div class="panel__eyebrow">{{ t.admin_pw_eyebrow }}</div>
          <h2 id="a-passwd">{{ t.admin_pw_h2 }}</h2>
        </div></div>
        <p class="section-foot">{{ t.admin_pw_foot|safe }}</p>
        <form hx-post="/admin/password" hx-target="#admin-result" hx-swap="innerHTML" class="admin-form">
          <input type="hidden" name="csrf" value="{{ token }}">
          <label class="control"><span class="control__label">{{ t.admin_pw_old }}</span>
            <input name="old" type="password" autocomplete="current-password" required class="control__input"></label>
          <label class="control"><span class="control__label">{{ t.admin_pw_new }}</span>
            <input name="new" type="password" autocomplete="new-password" minlength="8" required class="control__input"></label>
          <button type="submit" class="btn">{{ t.admin_pw_btn }}</button>
        </form>
      </section>
      {% endif %}

    </div>
  </main>

  <footer class="foot">
    {{ t.admin_footer|safe }}
  </footer>
</div>
</body>
</html>
