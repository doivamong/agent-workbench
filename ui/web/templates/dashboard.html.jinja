{#- Agent Workbench — web dashboard (shell). The static frame (head, topbar, day controls,
    scripts); the data-driven region lives in _body.html.jinja, wrapped in #dyn so HTMX can
    swap it on a day change / refresh without a full reload. UI text is localized via the i18n
    catalog (`t`) — Vietnamese by default, English via the EN/VI switcher. Charts read the
    embedded JSON in #chart-data (no fetch → offline); dashboard.js reads its one string from
    #i18n-data. -#}
<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ t.meta_title }}</title>
  <link rel="stylesheet" href="{{ url_for('static', filename='dashboard.css') }}">
  <script src="{{ url_for('static', filename='htmx.min.js') }}" defer></script>
</head>
<body>
<a class="skip" href="#noi-dung">{{ t.skip_to_content }}</a>

<div class="shell">

  {#- ===== Identity bar (static) ===== -#}
  <header class="topbar">
    <div class="topbar__row">
      <div class="topbar__mark">
        <svg class="topbar__logo" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2.5 20.5 7v10L12 21.5 3.5 17V7L12 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M8 11.5l2.6 2.6L16 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div>
          <div class="panel__eyebrow">{{ t.brand_eyebrow }}</div>
          <h1>{{ t.dash_h1 }} · {{ ctx.today }}</h1>
        </div>
      </div>
      <div class="topbar__meta">
        <span class="env-pill"><span class="env-pill__live" aria-hidden="true"></span> {{ t.pill_local }}</span>
        <span class="env-pill">{{ t.pill_branch }} <span class="kit-num">{{ ctx.branch }}</span></span>
        <span class="env-pill">{{ t.pill_commit }} <span class="kit-num">{{ ctx.commit }}</span></span>
        {% include "_lang_switch.html.jinja" %}
        <a class="btn" href="/admin/login">{{ t.admin_login_link }}</a>
      </div>
    </div>
    <p class="topbar__sub">
      {{ t.topbar_sub.format(n_skills=n_skills, n_hooks=ctx.n_hooks)|safe }}
    </p>

    {#- ===== Controls: day window + refresh (HTMX-swap #dyn) ===== -#}
    <div class="controls" role="group" aria-label="{{ t.controls_group_aria }}">
      <label class="control">
        <span class="control__label">{{ t.control_window }}</span>
        <select name="days" class="control__input"
                hx-get="/fragment" hx-target="#dyn" hx-swap="innerHTML"
                hx-include="[name='tier']" hx-trigger="change">
          {% for d in day_options %}
          <option value="{{ d }}" {{ 'selected' if d == days else '' }}>{{ d }} {{ t.days_unit }}</option>
          {% endfor %}
        </select>
      </label>
      <button type="button" class="btn"
              hx-get="/fragment" hx-target="#dyn" hx-swap="innerHTML"
              hx-include="[name='days'],[name='tier']">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M20 11A8 8 0 1 0 18 16M20 5v6h-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ t.btn_refresh }}
      </button>
      <span class="controls__hint muted" aria-live="polite">{{ t.controls_hint }}</span>
    </div>
  </header>

  {#- ===== Dynamic region (HTMX-swapped) ===== -#}
  <main id="noi-dung"><div id="dyn">{% include "_body.html.jinja" %}</div></main>

  <footer class="foot">
    {{ t.footer }}
    <span class="mono">{{ ctx.commit }}</span> · {{ ctx.today }}
  </footer>
</div>

{#- The one string dashboard.js needs (chart axis label), localized server-side. Lives in the
    static shell so it survives HTMX swaps of #dyn. -#}
<script id="i18n-data" type="application/json">{{ js_i18n|safe }}</script>
<script src="{{ url_for('static', filename='chart.min.js') }}"></script>
<script src="{{ url_for('static', filename='dashboard.js') }}"></script>
</body>
</html>
