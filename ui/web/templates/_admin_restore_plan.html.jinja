{#- Restore PREVIEW — the dry-run plan + the confirm form that carries the plan-hash back.
    The hash is the TOCTOU guard: /admin/restore/apply recomputes the plan and refuses if it
    no longer matches (the tree moved since this preview). Server takes an auto-backup first.
    UI copy via the i18n catalog (`t`); counts are filled with .format. -#}
<div class="admin-result" role="status" aria-live="polite">
  <div class="admin-result__head">
    <span class="admin-result__dot" aria-hidden="true"></span>
    <strong>{{ t.restore_preview_head }} · <span class="mono">{{ snapshot }}</span></strong>
  </div>
  <p class="admin-result__msg">
    {{ t.restore_plan_msg.format(create=plan.will_create|length, modify=plan.will_modify|length,
                                 unchanged=plan.unchanged|length, total=plan.files_total)|safe }}
  </p>
  {% if dirty %}
  <p class="admin-result__msg admin-result--err">
    {{ t.restore_dirty_warn|safe }}
  </p>
  {% endif %}
  <form hx-post="/admin/restore/apply" hx-target="#admin-result" hx-swap="innerHTML"
        hx-confirm="{{ t.restore_confirm.format(modify=plan.will_modify|length) }}"
        class="admin-form">
    <input type="hidden" name="csrf" value="{{ token }}">
    <input type="hidden" name="snapshot" value="{{ snapshot }}">
    <input type="hidden" name="plan_hash" value="{{ plan.plan_hash }}">
    <label class="admin-check">
      <input type="checkbox" name="allow_dirty">
      {{ t.restore_check_label|safe }}
    </label>
    <button type="submit" class="btn btn--danger">
      {{ t.restore_btn.format(modify=plan.will_modify|length) }}
    </button>
    <p class="admin-form__hint muted">
      {{ t.restore_hint.format(hash=plan.plan_hash[:16])|safe }}
    </p>
  </form>
</div>
