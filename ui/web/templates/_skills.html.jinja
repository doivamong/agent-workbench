{#- Skills table fragment. Rendered standalone by GET /fragment/skills (HTMX tier filter)
    and included by _body.html.jinja for the initial page. Iterates `skills_table` (already
    filtered by tier in app.build_view); `measured` drives the honesty states. UI text via
    the i18n catalog (`t`); the tier *id* (s.tier) stays English in the "Tier" column. -#}
<table class="tbl">
  <thead>
    <tr>
      <th scope="col">{{ t.th_skill }}</th>
      <th scope="col">{{ t.th_tier }}</th>
      <th scope="col" class="num">{{ t.th_namecalls }}</th>
      <th scope="col">{{ t.th_signal }}</th>
    </tr>
  </thead>
  <tbody>
    {% for s in skills_table %}
    <tr>
      <td><span class="cell-skill"><span class="dot dot--{{ s.tier }}"></span>{{ s.name }}</span></td>
      <td class="muted">{{ s.tier }}</td>
      {% if not measured %}
      <td class="num num--zero">—</td>
      <td><span class="badge">{{ t.badge_unmeasured }}</span></td>
      {% elif s.fired == 0 %}
      <td class="num num--zero">0</td>
      {% if s.tier == 'guard' %}
      <td><span class="badge badge--dead" title="{{ t.badge_guard_title }}">{{ t.badge_guard }}</span></td>
      {% else %}
      <td><span class="badge badge--dead" title="{{ t.badge_dead_title }}">{{ t.badge_dead }}</span></td>
      {% endif %}
      {% else %}
      <td class="num">{{ s.fired }}</td>
      <td><span class="badge badge--ok">{{ t.badge_named }}</span></td>
      {% endif %}
    </tr>
    {% else %}
    <tr><td colspan="4" class="muted" style="text-align:center;padding:var(--sp-5)">
      {{ t.skills_empty_tier }}</td></tr>
    {% endfor %}
  </tbody>
</table>
